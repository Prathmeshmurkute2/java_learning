@functionalInterface
interface Hello{
	String greet();
}

public class LambdaDemo {

	public LambdaDemo() {
		
	}

	public static void main(String[] args) {
		
		Hello h1 = () -> "Hello Lambda!";
		System.out.println(h1.greet());
		
		Hello h2 =()->{
			String msg = "Bonjour Lambda";
			return msg;
		};
		System.out.println(h2.greet());
	}

}
